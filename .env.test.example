# Copie este arquivo para .env.test e preencha os valores
PLAYWRIGHT_BASE_URL=http://localhost:3000

# URL e chaves do projeto Supabase usado nos testes
# Use um projeto separado ou o mesmo de desenvolvimento
E2E_SUPABASE_URL=https://SEU_PROJETO.supabase.co
E2E_SUPABASE_SERVICE_KEY=sua_service_role_key_aqui
E2E_SUPABASE_ANON_KEY=sua_anon_key_aqui

# E-mail do usuário criado automaticamente pelo global-setup
E2E_TEST_EMAIL=e2e-tests@rentflow.com
